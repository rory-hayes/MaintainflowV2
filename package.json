{
  "name": "maintain-flow",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.3",
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "postbuild": "node scripts/apply-self-serve-workspace-access.mjs",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "node --test --experimental-strip-types --experimental-specifier-resolution=node tests/*.test.mts",
    "test:e2e": "node --test --experimental-strip-types --experimental-specifier-resolution=node tests/core-loop.test.mts",
    "test:business-evals:e2e": "playwright test --config=playwright.business-evals.config.ts",
    "test:business-evals:database": "node scripts/business-evals-database-acceptance.mjs",
    "smoke:cron": "node scripts/smoke-cron.mjs",
    "smoke:production": "node scripts/production-smoke.mjs",
    "smoke:canary": "node scripts/production-smoke.mjs --stage=canary",
    "smoke:production:supabase": "node --experimental-strip-types scripts/live-assurance-supabase-smoke.mjs",
    "deploy:check": "node scripts/local-deploy-readiness.mjs",
    "deploy:check:canary": "node scripts/local-deploy-readiness.mjs --stage=canary",
    "vercel:env:check": "node scripts/push-vercel-env.mjs --environment production --dry-run",
    "vercel:env:check:canary": "node scripts/push-vercel-env.mjs --environment production --stage canary --dry-run",
    "vercel:env:push": "node scripts/push-vercel-env.mjs --environment production",
    "vercel:env:push:canary": "node scripts/push-vercel-env.mjs --environment production --stage canary"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@browserbasehq/sdk": "2.16.0",
    "@noble/hashes": "1.8.0",
    "@react-pdf/renderer": "^4.5.1",
    "@tabler/icons-react": "^3.40.0",
    "@tanstack/react-query": "5.101.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.40.0",
    "input-otp": "^1.4.2",
    "lenis": "^1.3.18",
    "motion": "^12.36.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "ogl": "^1.0.11",
    "pg": "^8.22.0",
    "playwright-core": "1.61.1",
    "react": "19.2.7",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.7",
    "react-icons": "^5.6.0",
    "react-resizable-panels": "^4.7.2",
    "recharts": "^2.15.4",
    "resend": "6.17.2",
    "shadcn": "^4.0.6",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "workflow": "4.6.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "postcss": "8.5.10",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
